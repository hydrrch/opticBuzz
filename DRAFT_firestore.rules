rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.brand is string && data.brand.size() <= 50;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidPrescription(data) {
      return data.userId == request.auth.uid &&
             data.type in ['single-vision', 'bifocal', 'progressive'] &&
             data.verified is bool;
    }

    // Collection: Admins (Bootstrap)
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // Collection: Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // Collection: Users
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      // Extra protection against privilege escalation
      allow update: if isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role']);
    }

    // Collection: Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled' && existing().status == 'pending') ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // Collection: Prescriptions
    match /prescriptions/{prescriptionId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidPrescription(incoming()) && incoming().verified == false;
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['verified']);
    }
  }
}
