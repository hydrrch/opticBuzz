rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // Note: admins collection should contain documents with admin UIDs
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 0.2 Validation Blueprints (Eight Pillars)
    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.brand is string && data.brand.size() <= 50 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 50;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.items.size() <= 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidPrescription(data) {
      return data.userId == request.auth.uid &&
             data.type in ['single-vision', 'bifocal', 'progressive'] &&
             data.verified is bool;
    }

    // Collection: Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }

    // Collection: Products
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && incoming().uid == userId && incoming().role == 'customer';
      allow update: if isOwner(userId) && 
                      // Prevent role hijacking
                      !incoming().diff(existing()).affectedKeys().hasAny(['role', 'uid', 'email']) &&
                      incoming().uid == existing().uid;
    }

    // Collection: Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidOrder(incoming()) && 
                    incoming().createdAt == request.time &&
                    isValidId(orderId);
      
      allow update: if isSignedIn() && (
        // Action: Customer Cancel
        (isOwner(existing().userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) && 
         incoming().status == 'cancelled' && 
         existing().status == 'pending') ||
        
        // Action: Admin Update
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // Collection: Prescriptions
    match /prescriptions/{prescriptionId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidPrescription(incoming()) && 
                    incoming().verified == false &&
                    incoming().createdAt == request.time &&
                    isValidId(prescriptionId);
                    
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['verified', 'verifiedAt']) &&
                      incoming().verifiedAt == request.time;
    }
  }
}
